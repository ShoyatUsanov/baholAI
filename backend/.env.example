# baholAI backend
APP_NAME=baholAI
APP_ENV=development
APP_PORT=8002
APP_DEBUG=true

# CORS — baholAI frontend + any extra origins
FRONTEND_ORIGIN=http://localhost:5175
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Database (async SQLite)
DATABASE_URL=sqlite+aiosqlite:///./baholai.db

# ---- AI (local-first) ----
# Local LLM via Ollama. Leave the daemon off to use the rule-based fallback.
AI_ENABLED=true
OLLAMA_URL=http://localhost:11434
# baholAI's tuned model (build it: ollama create baholai -f ollama/baholai.Modelfile).
# Or use the base directly, e.g. qwen2.5:3b. Daemon off → rule-based fallback.
AI_MODEL=baholai
AI_LANGUAGE=uz
AI_TIMEOUT_SECONDS=30
